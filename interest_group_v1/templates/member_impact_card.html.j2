{# federation_flexible_v1 — member_impact_card.html.j2
   Single sector-cut impact card. Reusable include / standalone.
   Configurable per federation via palette. Renders one focused finding
   with: a stat, a one-line plain-language framing, and the source.
   Context: { palette, federation, impact }
   impact shape: { headline, stat, framing, source_label, source_url } #}
<article class="member-impact" data-palette="{{ palette|default('base')|e }}">
  <h3 class="member-impact__h" style="font-size:18px;color:var(--fed-accent);margin-bottom:var(--sp-3);">
    {{ impact.headline|e }}
  </h3>
  <p style="font-family:var(--ff-numeric);font-weight:700;font-size:36px;color:var(--fed-accent);line-height:1.05;margin:0 0 var(--sp-3) 0;letter-spacing:-0.02em;">
    {{ impact.stat|e }}
  </p>
  <p style="font-family:var(--ff-body);font-size:16px;color:var(--fed-ink);line-height:var(--lh-snug);margin:0 0 var(--sp-3) 0;">
    {{ impact.framing|e }}
  </p>
  {% if impact.source_label %}
  <p style="font-family:var(--ff-heading);font-size:12px;color:var(--fed-ink-muted);margin:0;font-style:italic;">
    {{ ui.source|default('Quelle') }}&nbsp;:
    {% if impact.source_url %}
    <a href="{{ impact.source_url }}" style="color:var(--fed-ink-muted);">{{ impact.source_label|e }}</a>
    {% else %}
    {{ impact.source_label|e }}
    {% endif %}
  </p>
  {% endif %}
</article>
