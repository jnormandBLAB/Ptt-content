{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Federation-flexible token kit for interest_group_v1. Base palette + 3 swap-in palettes (USP agriculture green/brown, SGB union red/black, pro Senectute teal/cream) selected at render time via data-palette attribute. Variable Source Serif 4 + Inter, member-friendly large body type. Reference NAVY/GOLD via {color.brand.navy.value} — never inline.",
  "$kit": "federation_flexible_v1",
  "$package_id": "interest_group_v1",
  "$version": "1.0.0",

  "color": {
    "brand": {
      "navy":       { "$value": "#1B2A4A", "$type": "color", "$description": "Canonical PTT navy." },
      "gold":       { "$value": "#C9A84C", "$type": "color", "$description": "Canonical PTT gold." },
      "white":      { "$value": "#FFFFFF", "$type": "color", "$description": "Canonical PTT white." },
      "body":       { "$value": "#2C2C2C", "$type": "color", "$description": "Canonical PTT body text." },
      "light_gray": { "$value": "#F5F5F5", "$type": "color", "$description": "Canonical PTT light gray." }
    },
    "fed_base": {
      "$description": "Default federation palette (used when no data-palette attribute is set).",
      "ink":           { "$value": "#1F2937", "$type": "color", "$description": "On paper: 13.6:1." },
      "ink_secondary": { "$value": "#4B5563", "$type": "color", "$description": "On paper: 7.5:1." },
      "ink_muted":     { "$value": "#6B7280", "$type": "color" },
      "paper":         { "$value": "#FAFAF7", "$type": "color", "$description": "Member-newsletter cream-white. Restful at 17pt body." },
      "panel":         { "$value": "#F1EFE8", "$type": "color" },
      "accent":        { "$value": "#1B2A4A", "$type": "color", "$description": "Default accent — navy. Each palette overrides." },
      "accent_soft":   { "$value": "#E5E7EB", "$type": "color" },
      "rule_med":      { "$value": "#9CA3AF", "$type": "color" },
      "rule_hair":     { "$value": "#D1D5DB", "$type": "color" },
      "cta":           { "$value": "#7A6A24", "$type": "color", "$description": "'Was bedeutet das für unsere Mitglieder' bar — gold-deep, AAA on white: 7.1:1." }
    },
    "fed_usp": {
      "$description": "Schweizer Bauernverband palette — agriculture green + earth brown.",
      "accent":        { "$value": "#3F6B2A", "$type": "color", "$description": "USP green. On white: 5.5:1." },
      "accent_soft":   { "$value": "#E1ECDA", "$type": "color" },
      "panel":         { "$value": "#F4EFE6", "$type": "color", "$description": "Earth-paper." },
      "ink":           { "$value": "#2A2418", "$type": "color", "$description": "Walnut ink. On panel: 13.0:1." },
      "cta":           { "$value": "#7B4A1F", "$type": "color", "$description": "Soil-brown CTA. On white: 6.4:1." },
      "rule_med":      { "$value": "#A99977", "$type": "color" }
    },
    "fed_sgb": {
      "$description": "Schweizerischer Gewerkschaftsbund palette — union red + black.",
      "accent":        { "$value": "#B91C1C", "$type": "color", "$description": "Union red. On white: 6.7:1." },
      "accent_soft":   { "$value": "#FEE2E2", "$type": "color" },
      "panel":         { "$value": "#F4F2EE", "$type": "color" },
      "ink":           { "$value": "#0A0A0A", "$type": "color", "$description": "Near-black. On white: 19.3:1." },
      "cta":           { "$value": "#0A0A0A", "$type": "color", "$description": "Black CTA bar — solidarity convention." },
      "rule_med":      { "$value": "#737373", "$type": "color" }
    },
    "fed_pro_senectute": {
      "$description": "pro Senectute palette — senior teal + cream. Higher contrast for older readers.",
      "accent":        { "$value": "#0E7490", "$type": "color", "$description": "Senior teal. On white: 5.7:1." },
      "accent_soft":   { "$value": "#CFFAFE", "$type": "color" },
      "panel":         { "$value": "#FEFAEE", "$type": "color", "$description": "Cream paper — easier on aged retinas than pure white." },
      "ink":           { "$value": "#111827", "$type": "color", "$description": "Black. On cream: 16.4:1." },
      "cta":           { "$value": "#0E7490", "$type": "color" },
      "rule_med":      { "$value": "#94A3B8", "$type": "color" }
    },
    "data": {
      "score_excellent":  { "$value": "#1B5E20", "$type": "color" },
      "score_good":       { "$value": "#2E7D32", "$type": "color" },
      "score_moderate":   { "$value": "#F9A825", "$type": "color" },
      "score_poor":       { "$value": "#E65100", "$type": "color" },
      "score_critical":   { "$value": "#C62828", "$type": "color" }
    },
    "text": {
      "default":   { "$value": "{color.fed_base.ink.value}", "$type": "color" },
      "muted":     { "$value": "{color.fed_base.ink_secondary.value}", "$type": "color" },
      "on_navy":   { "$value": "{color.brand.white.value}", "$type": "color" },
      "on_gold":   { "$value": "{color.brand.navy.value}", "$type": "color" }
    }
  },

  "typography": {
    "font_family": {
      "heading": { "$value": "Inter, -apple-system, BlinkMacSystemFont, sans-serif", "$type": "fontFamily", "$description": "Inter heading — neutral across federations." },
      "body":    { "$value": "\"Source Serif 4\", Charter, Georgia, serif", "$type": "fontFamily", "$description": "Serif body — newsletter-grade readability for older members." },
      "numeric": { "$value": "Inter, ui-monospace, monospace", "$type": "fontFamily", "$description": "Tabular figures." }
    },
    "font_size": {
      "h1":         { "$value": "28pt", "$type": "dimension" },
      "h2":         { "$value": "18pt", "$type": "dimension" },
      "h3":         { "$value": "14pt", "$type": "dimension" },
      "body":       { "$value": "12pt", "$type": "dimension", "$description": "Member-newsletter body — generous, NOT dense." },
      "body_web":   { "$value": "17px", "$type": "dimension", "$description": "Larger than other kits — federation members skew older." },
      "caption":    { "$value": "10pt", "$type": "dimension" },
      "footnote":   { "$value": "9pt",  "$type": "dimension" },
      "hero_stat":  { "$value": "44pt", "$type": "dimension" }
    },
    "line_height": {
      "tight":  { "$value": "1.15", "$type": "number" },
      "snug":   { "$value": "1.30", "$type": "number" },
      "normal": { "$value": "1.55", "$type": "number" },
      "loose":  { "$value": "1.70", "$type": "number" }
    },
    "scale_ratio": { "$value": "1.250", "$type": "number" },
    "font_weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "numerals": { "$value": "lining", "$type": "string" }
  },

  "spacing": {
    "0": { "$value": "0",    "$type": "dimension" },
    "1": { "$value": "2pt",  "$type": "dimension" },
    "2": { "$value": "4pt",  "$type": "dimension" },
    "3": { "$value": "6pt",  "$type": "dimension" },
    "4": { "$value": "8pt",  "$type": "dimension" },
    "5": { "$value": "12pt", "$type": "dimension" },
    "6": { "$value": "16pt", "$type": "dimension" },
    "7": { "$value": "24pt", "$type": "dimension" },
    "8": { "$value": "32pt", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",   "$type": "dimension" },
    "sm":   { "$value": "2px", "$type": "dimension" },
    "md":   { "$value": "6px", "$type": "dimension", "$description": "Member-card radius — softer than executive kits." }
  },

  "shadow": { "none": { "$value": "none", "$type": "shadow" } },

  "motion": { "respect_reduced_motion": { "$value": true, "$type": "boolean" } },

  "layout": {
    "max_content_width":   { "$value": "720px", "$type": "dimension", "$description": "Slightly narrower than other kits — newsletter convention." },
    "print_a4_w":          { "$value": "210mm", "$type": "dimension" },
    "print_a4_h":          { "$value": "297mm", "$type": "dimension" },
    "print_a4_margin":     { "$value": "20mm",  "$type": "dimension" }
  },

  "audio": {
    "tts_target_seconds":  { "$value": 90,  "$type": "number", "$description": "Audio summary duration — 1m30s." },
    "words_fr":            { "$value": 150, "$type": "number" },
    "words_de":            { "$value": 180, "$type": "number" },
    "words_it":            { "$value": 165, "$type": "number" },
    "voice_register":      { "$value": "warm_explanatory", "$type": "string" }
  },

  "accessibility": {
    "min_contrast_body":  { "$value": 7.0, "$type": "number" },
    "min_contrast_large": { "$value": 4.5, "$type": "number" },
    "min_touch_target":   { "$value": "48px", "$type": "dimension", "$description": "Larger than the 44px floor — older audiences." }
  }
}
