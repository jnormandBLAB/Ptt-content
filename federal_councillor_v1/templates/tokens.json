{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Executive dark-compact token kit for federal_councillor_v1. Sober NAVY + GOLD + cream paper surface. Compact scale (11pt body), tabular figures throughout, AAA contrast targets for podium-light reading. Reference style: Strategy& 1-pager, Confédération note de service.",
  "$kit": "executive_dark_compact",
  "$package_id": "federal_councillor_v1",
  "$version": "1.0.0",

  "color": {
    "brand": {
      "navy":       { "$value": "#1B2A4A", "$type": "color" },
      "gold":       { "$value": "#C9A84C", "$type": "color" },
      "white":      { "$value": "#FFFFFF", "$type": "color" },
      "body":       { "$value": "#2C2C2C", "$type": "color" },
      "light_gray": { "$value": "#F5F5F5", "$type": "color" }
    },
    "exec": {
      "ink":         { "$value": "#0F1A30", "$type": "color", "$description": "Deeper navy for runs of body text on cream — darker than brand navy because cream surface absorbs blue. Contrast on cream: 14.2:1." },
      "ink_muted":   { "$value": "#3D4257", "$type": "color", "$description": "Muted body for secondary lines (subtitles, timestamps). Contrast on cream: 8.7:1." },
      "cream_paper": { "$value": "#F2EBDA", "$type": "color", "$description": "Confédération note paper. Warmer than the citizen cream so it photographs neutral under tungsten podium lights." },
      "rule_strong": { "$value": "#1B2A4A", "$type": "color", "$description": "1pt rule under page header." },
      "rule_hair":   { "$value": "#C7C0AC", "$type": "color", "$description": "0.25pt hairlines between table rows." },
      "highlight":   { "$value": "#FFF6CC", "$type": "color", "$description": "Sparing highlight behind the recommendation line. Never used for chart fills." }
    },
    "data": {
      "trajectory_act_now":  { "$value": "#1D9E75", "$type": "color", "$description": "Mirrors PTT TEAL." },
      "trajectory_delay":    { "$value": "#854F0B", "$type": "color", "$description": "Mirrors PTT AMBER." },
      "trajectory_inaction": { "$value": "#A32D2D", "$type": "color", "$description": "Mirrors PTT RED." },
      "score_excellent":     { "$value": "#1B5E20", "$type": "color" },
      "score_good":          { "$value": "#2E7D32", "$type": "color" },
      "score_moderate":      { "$value": "#F9A825", "$type": "color" },
      "score_poor":          { "$value": "#E65100", "$type": "color" },
      "score_critical":      { "$value": "#C62828", "$type": "color" }
    },
    "text": {
      "default":   { "$value": "{color.exec.ink.value}", "$type": "color" },
      "muted":     { "$value": "{color.exec.ink_muted.value}", "$type": "color" },
      "on_navy":   { "$value": "{color.brand.white.value}", "$type": "color" },
      "on_gold":   { "$value": "{color.brand.navy.value}", "$type": "color" },
      "watermark": { "$value": "rgba(27,42,74,0.08)", "$type": "color", "$description": "Personalised watermark — 8% navy, repeated diagonally per recipient." }
    }
  },

  "typography": {
    "font_family": {
      "heading": { "$value": "Inter, -apple-system, sans-serif", "$type": "fontFamily", "$description": "Sans-serif heading anchors the eye on 1-page A4." },
      "body":    { "$value": "\"Source Serif 4\", Charter, Georgia, serif", "$type": "fontFamily", "$description": "Serif body for prolonged reading authority — federal note convention." },
      "numeric": { "$value": "\"Source Serif 4\", ui-monospace, monospace", "$type": "fontFamily", "$description": "Tabular figures via OpenType `tnum`; the serif numeric pairs with the body family." }
    },
    "font_size": {
      "display":   { "$value": "28pt", "$type": "dimension", "$description": "Composite score on hero card." },
      "h1":        { "$value": "16pt", "$type": "dimension" },
      "h2":        { "$value": "13pt", "$type": "dimension" },
      "h3":        { "$value": "11pt", "$type": "dimension" },
      "body":      { "$value": "11pt", "$type": "dimension", "$description": "A4 body floor — Confédération note convention." },
      "body_web":  { "$value": "16px", "$type": "dimension", "$description": "Web echo of the print body." },
      "caption":   { "$value": "9pt",  "$type": "dimension" },
      "footnote":  { "$value": "8pt",  "$type": "dimension" }
    },
    "line_height": {
      "tight":  { "$value": "1.10", "$type": "number", "$description": "Display-only." },
      "snug":   { "$value": "1.25", "$type": "number" },
      "normal": { "$value": "1.40", "$type": "number", "$description": "Compact — body sits tight to fit one A4." },
      "loose":  { "$value": "1.55", "$type": "number" }
    },
    "scale_ratio": { "$value": "1.200", "$type": "number", "$description": "Minor third — compact, federal." },
    "font_weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "numerals": { "$value": "tabular", "$type": "string", "$description": "Tabular figures everywhere — KPI columns must align decimally." }
  },

  "spacing": {
    "0": { "$value": "0",    "$type": "dimension" },
    "1": { "$value": "2pt",  "$type": "dimension" },
    "2": { "$value": "4pt",  "$type": "dimension" },
    "3": { "$value": "6pt",  "$type": "dimension" },
    "4": { "$value": "8pt",  "$type": "dimension" },
    "5": { "$value": "12pt", "$type": "dimension" },
    "6": { "$value": "16pt", "$type": "dimension" },
    "7": { "$value": "24pt", "$type": "dimension" },
    "8": { "$value": "32pt", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",   "$type": "dimension" },
    "sm":   { "$value": "2px", "$type": "dimension", "$description": "Federal sober — radius is almost zero." },
    "md":   { "$value": "4px", "$type": "dimension" }
  },

  "shadow": {
    "none": { "$value": "none", "$type": "shadow", "$description": "Federal kit ships zero shadows. Print-first." }
  },

  "motion": {
    "duration": { "instant": { "$value": "0ms", "$type": "duration" } },
    "respect_reduced_motion": { "$value": true, "$type": "boolean" }
  },

  "layout": {
    "max_content_width":   { "$value": "780px", "$type": "dimension", "$description": "Web echo of A4 (210mm at 96dpi ≈ 794px)." },
    "print_a4_w":          { "$value": "210mm", "$type": "dimension" },
    "print_a4_h":          { "$value": "297mm", "$type": "dimension" },
    "print_a4_margin_top": { "$value": "18mm",  "$type": "dimension" },
    "print_a4_margin":     { "$value": "16mm",  "$type": "dimension" },
    "pptx_w_in":           { "$value": "13.333", "$type": "number", "$description": "16:9 widescreen PPTX." },
    "pptx_h_in":           { "$value": "7.5",   "$type": "number" }
  },

  "accessibility": {
    "min_contrast_body":  { "$value": 7.0, "$type": "number", "$description": "Federal kit targets WCAG AAA — readable under variable podium light." },
    "min_contrast_large": { "$value": 4.5, "$type": "number" },
    "min_touch_target":   { "$value": "44px", "$type": "dimension" }
  }
}
