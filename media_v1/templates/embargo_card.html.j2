{# editorial_press_v1 — embargo_card.html.j2
   Single-card embargo notice + contact, sent ahead of the release.
   Context: { lang, topic, embargo, contact, conditions[], audit_url } #}
<!DOCTYPE html>
<html lang="{{ lang|default('de') }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  <meta name="robots" content="noindex,nofollow">
  <title>{{ ui.embargo|default('SPERRFRIST') }} — {{ topic|e }}</title>
  <link rel="stylesheet" href="kit.css">
</head>
<body>
  <a href="#main" class="skip-link">{{ ui.skip_to_content|default('Zum Inhalt') }}</a>

  <div class="embargo-banner" role="alert">
    {{ ui.embargo|default('SPERRFRIST BIS') }}
    <span class="embargo-banner__time">{{ embargo.release_at|e }} ({{ embargo.tz|default('CET') }})</span>
  </div>

  <main id="main" class="press-release">

    <header class="masthead">
      <span class="masthead__brand">PTT Platform · {{ ui.embargo_card|default('Sperrfrist-Karte') }}</span>
      <span class="masthead__date">{{ embargo.issued_at|e }}</span>
    </header>

    <p class="dateline">{{ topic|e }}</p>
    <h1 class="headline" style="font-size:24px;">{{ ui.embargo_card_h|default('Embargo-Bedingungen') }}</h1>

    <p class="lede">
      {{ ui.embargo_lede|default('Diese Information ist gesperrt bis zum unten angegebenen Zeitpunkt. Veröffentlichung vor diesem Zeitpunkt verstösst gegen das Embargo.') }}
    </p>

    {% if conditions %}
    <ul>
      {% for c in conditions %}<li>{{ c|e }}</li>{% endfor %}
    </ul>
    {% endif %}

    <aside class="backgrounder">
      <p class="backgrounder__h">{{ ui.release_window|default('Veröffentlichungsfenster') }}</p>
      <p>
        <strong>{{ ui.release_at|default('Freigabe') }}&nbsp;:</strong> {{ embargo.release_at|e }} ({{ embargo.tz|default('CET') }})<br>
        {% if embargo.lift_at %}<strong>{{ ui.lift_at|default('Aufhebung') }}&nbsp;:</strong> {{ embargo.lift_at|e }}<br>{% endif %}
        {% if embargo.contact_at %}<strong>{{ ui.queries|default('Rückfragen ab') }}&nbsp;:</strong> {{ embargo.contact_at|e }}{% endif %}
      </p>
    </aside>

    {% if contact %}
    <section class="contact-card" aria-labelledby="contact-h">
      <p id="contact-h" class="contact-card__name">{{ contact.name|e }}</p>
      {% if contact.role %}<p class="contact-card__row">{{ contact.role|e }}</p>{% endif %}
      {% if contact.phone %}
      <p class="contact-card__row"><span class="contact-card__label">{{ ui.phone|default('Tel.') }}</span> <a href="tel:{{ contact.phone|e }}">{{ contact.phone|e }}</a></p>
      {% endif %}
      {% if contact.email %}
      <p class="contact-card__row"><span class="contact-card__label">{{ ui.email|default('E-Mail') }}</span> <a href="mailto:{{ contact.email|e }}">{{ contact.email|e }}</a></p>
      {% endif %}
      {% if contact.window %}
      <p class="contact-card__row"><span class="contact-card__label">{{ ui.window|default('Fenster') }}</span> {{ contact.window|e }}</p>
      {% endif %}
    </section>
    {% endif %}

    <footer class="audit-footer">
      <span>Audit: <a href="{{ audit_url }}">{{ audit_url }}</a></span>
      <span>{{ ui.license|default('Lizenz') }}: pre-embargo, internal newsroom only</span>
    </footer>

  </main>
</body>
</html>
