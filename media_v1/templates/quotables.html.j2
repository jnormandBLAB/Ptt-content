{# editorial_press_v1 — quotables.html.j2
   10-line quotable sheet. Each line carries: text, attribution, claim_id,
   confidence label (high|medium|low|contested), source URL.
   Context: { lang, topic, embargo, dateline, quotables[10],
              audit_url, license, attribution } #}
<!DOCTYPE html>
<html lang="{{ lang|default('de') }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  {% if embargo %}<meta name="robots" content="noindex,nofollow">{% endif %}
  <title>{{ ui.quotables|default('Zitierbare Sätze') }} — {{ topic|e }}</title>
  <link rel="stylesheet" href="kit.css">
  <style>:root { --audit-url: "{{ audit_url }}"; }</style>
</head>
<body class="{{ 'watermarked' if embargo else '' }}">
  <a href="#main" class="skip-link">{{ ui.skip_to_content|default('Zum Inhalt') }}</a>

  {% if embargo %}
  <div class="embargo-banner" role="note">
    {{ ui.embargo|default('SPERRFRIST') }}
    <span class="embargo-banner__time">{{ embargo.release_at|e }} ({{ embargo.tz|default('CET') }})</span>
  </div>
  {% endif %}

  <main id="main">

    <header class="masthead">
      <span class="masthead__brand">PTT Platform · {{ ui.quotables|default('Zitierbare Sätze') }}</span>
      <span class="masthead__date">{{ dateline.date|e }}</span>
    </header>

    <p class="dateline">{{ topic|e }}</p>
    <h1 class="headline" style="font-size:28px;">{{ ui.quotables|default('Zitierbare Sätze') }}</h1>
    <p class="lede">{{ ui.quotables_lede|default('Zehn integrationsbereite Sätze. Jede Zeile trägt eine Quelle, eine Claim-Nummer und ein Vertrauenslabel.') }}</p>

    <ol class="quotables">
      {% for q in quotables[:10] %}
      <li class="quotables__item">
        <p class="quotables__num">Q{{ '%02d' % loop.index }}
          {% if q.confidence %}
          <span class="confidence-badge confidence-badge--{{ q.confidence|lower|e }}">{{ q.confidence|e }}</span>
          {% endif %}
        </p>
        <blockquote class="quotables__line">{{ q.line|e }}</blockquote>
        <p class="quotables__meta">
          <strong>{{ q.attribution|e }}</strong>{% if q.role %} · {{ q.role|e }}{% endif %}<br>
          claim:&nbsp;{{ q.claim_id|e }}
          {% if q.source_url %} · <a href="{{ q.source_url }}">{{ q.source_label|default(q.source_url)|e }}</a>{% endif %}
        </p>
      </li>
      {% endfor %}
    </ol>

    <footer class="audit-footer">
      <span>Audit: <a href="{{ audit_url }}">{{ audit_url }}</a></span>
      <span>{{ ui.license|default('Lizenz') }}: {{ license|default('CC-BY-4.0') }}</span>
      <span>{{ attribution|e }}</span>
    </footer>

  </main>
</body>
</html>
