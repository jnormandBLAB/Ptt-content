{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Editorial press kit for media_v1. Editorial NAVY + GOLD + neutral grays inspired by FT Visual Stories and Reuters/AP press kits. Charts in transparent-bg variants for newsroom drop-in. Tabular numerals for figures. Embargo red watermark token reserved for the embargo channel only. Reference NAVY/GOLD via {color.brand.navy.value} — never inline.",
  "$kit": "editorial_press_v1",
  "$package_id": "media_v1",
  "$version": "1.0.0",

  "color": {
    "brand": {
      "navy":       { "$value": "#1B2A4A", "$type": "color", "$description": "Canonical PTT navy." },
      "gold":       { "$value": "#C9A84C", "$type": "color", "$description": "Canonical PTT gold." },
      "white":      { "$value": "#FFFFFF", "$type": "color", "$description": "Canonical PTT white." },
      "body":       { "$value": "#2C2C2C", "$type": "color", "$description": "Canonical PTT body text." },
      "light_gray": { "$value": "#F5F5F5", "$type": "color", "$description": "Canonical PTT light gray." }
    },
    "press": {
      "ink":               { "$value": "#0E1320", "$type": "color", "$description": "Editorial body ink. On white: 17.9:1." },
      "ink_secondary":     { "$value": "#3F4A5C", "$type": "color", "$description": "Caption / source-citation. On white: 9.1:1." },
      "ink_muted":         { "$value": "#6B7280", "$type": "color", "$description": "Dateline / byline. On white: 4.8:1." },
      "paper":             { "$value": "#FFFFFF", "$type": "color", "$description": "Pure-white press paper. Transparent-bg charts merge cleanly into any host page." },
      "paper_alt":         { "$value": "#F8F7F4", "$type": "color", "$description": "Backgrounder pull-out box (FT pink-substitute, restrained for federal context)." },
      "rule_strong":       { "$value": "#0E1320", "$type": "color", "$description": "1pt page rule under masthead." },
      "rule_med":          { "$value": "#C2C7D0", "$type": "color", "$description": "0.5pt section divider." },
      "rule_hair":         { "$value": "#E5E7EB", "$type": "color", "$description": "0.25pt table hairlines." },
      "pull_quote_bar":    { "$value": "#C9A84C", "$type": "color", "$description": "3pt left bar on pull-quotes — gold accent only." },
      "embargo_red":       { "$value": "#B91C1C", "$type": "color", "$description": "Embargo banner + watermark colour. On white: 6.7:1. NEVER used outside the embargo channel." },
      "embargo_red_soft":  { "$value": "#FEE2E2", "$type": "color", "$description": "Soft embargo banner background." },
      "annotation_badge":  { "$value": "#1B2A4A", "$type": "color", "$description": "Confidence label badge background." }
    },
    "data": {
      "score_excellent":   { "$value": "#1B5E20", "$type": "color" },
      "score_good":        { "$value": "#2E7D32", "$type": "color" },
      "score_moderate":    { "$value": "#F9A825", "$type": "color" },
      "score_poor":        { "$value": "#E65100", "$type": "color" },
      "score_critical":    { "$value": "#C62828", "$type": "color" },
      "chart_bg":          { "$value": "transparent", "$type": "color", "$description": "Press chart background — transparent so newsroom CMS controls the surface." },
      "chart_grid":        { "$value": "#E5E7EB", "$type": "color", "$description": "Grid lines on transparent. Visible on white, fades on dark host pages." }
    },
    "text": {
      "default":   { "$value": "{color.press.ink.value}", "$type": "color" },
      "muted":     { "$value": "{color.press.ink_secondary.value}", "$type": "color" },
      "byline":    { "$value": "{color.press.ink_muted.value}", "$type": "color" },
      "on_navy":   { "$value": "{color.brand.white.value}", "$type": "color" },
      "on_gold":   { "$value": "{color.brand.navy.value}", "$type": "color" },
      "on_red":    { "$value": "{color.brand.white.value}", "$type": "color" }
    }
  },

  "typography": {
    "font_family": {
      "heading":  { "$value": "Inter, -apple-system, BlinkMacSystemFont, sans-serif", "$type": "fontFamily", "$description": "Inter heading — wire-service neutral." },
      "body":     { "$value": "\"Source Serif 4\", Charter, Georgia, serif", "$type": "fontFamily", "$description": "Serif body — long-form readability for backgrounder + chart pack." },
      "numeric":  { "$value": "\"Inter\", ui-monospace, monospace", "$type": "fontFamily", "$description": "Tabular figures via OpenType `tnum 1, lnum 1`." },
      "byline":   { "$value": "Inter, sans-serif", "$type": "fontFamily" }
    },
    "font_size": {
      "headline":   { "$value": "32pt", "$type": "dimension", "$description": "Press release H1. Hard cap at 80 chars by renderer." },
      "headline_web":{"$value": "40px", "$type": "dimension" },
      "lede":       { "$value": "14pt", "$type": "dimension" },
      "h2":         { "$value": "16pt", "$type": "dimension" },
      "h3":         { "$value": "12pt", "$type": "dimension" },
      "body":       { "$value": "11pt", "$type": "dimension" },
      "body_web":   { "$value": "16px", "$type": "dimension" },
      "caption":    { "$value": "9pt",  "$type": "dimension" },
      "footnote":   { "$value": "8pt",  "$type": "dimension" },
      "embargo":    { "$value": "13pt", "$type": "dimension" },
      "pull_quote": { "$value": "20pt", "$type": "dimension" }
    },
    "line_height": {
      "tight":  { "$value": "1.10", "$type": "number" },
      "snug":   { "$value": "1.30", "$type": "number" },
      "normal": { "$value": "1.50", "$type": "number" },
      "loose":  { "$value": "1.65", "$type": "number" }
    },
    "scale_ratio": { "$value": "1.250", "$type": "number" },
    "font_weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "numerals": { "$value": "tabular", "$type": "string" },
    "max_headline_chars": { "$value": 80, "$type": "number", "$description": "Renderer hard limit. Wire-service convention." },
    "max_lede_words": { "$value": 30, "$type": "number" }
  },

  "spacing": {
    "0": { "$value": "0",    "$type": "dimension" },
    "1": { "$value": "2pt",  "$type": "dimension" },
    "2": { "$value": "4pt",  "$type": "dimension" },
    "3": { "$value": "6pt",  "$type": "dimension" },
    "4": { "$value": "8pt",  "$type": "dimension" },
    "5": { "$value": "12pt", "$type": "dimension" },
    "6": { "$value": "16pt", "$type": "dimension" },
    "7": { "$value": "24pt", "$type": "dimension" },
    "8": { "$value": "32pt", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",   "$type": "dimension" },
    "sm":   { "$value": "2px", "$type": "dimension" }
  },

  "shadow": {
    "none": { "$value": "none", "$type": "shadow" }
  },

  "motion": {
    "respect_reduced_motion": { "$value": true, "$type": "boolean" }
  },

  "layout": {
    "max_content_width":   { "$value": "780px", "$type": "dimension" },
    "press_release_w":     { "$value": "680px", "$type": "dimension", "$description": "Single-column press release width — matches AP wire layouts." },
    "chart_pack_row_h":    { "$value": "320px", "$type": "dimension", "$description": "One chart per row in the chart pack." },
    "print_a4_w":          { "$value": "210mm", "$type": "dimension" },
    "print_a4_h":          { "$value": "297mm", "$type": "dimension" },
    "print_a4_margin":     { "$value": "18mm",  "$type": "dimension" },
    "pptx_w_in":           { "$value": "13.333", "$type": "number" },
    "pptx_h_in":           { "$value": "7.5",   "$type": "number" },
    "oembed_default_w":    { "$value": 800, "$type": "number" },
    "oembed_default_h":    { "$value": 480, "$type": "number" }
  },

  "watermark": {
    "embargo_text":  { "$value": "EMBARGOED", "$type": "string", "$description": "Watermark text rendered when artefact is in embargo window." },
    "embargo_color": { "$value": "#B91C1C",   "$type": "color",  "$description": "Embargo watermark colour at 12% opacity." },
    "embargo_opacity": { "$value": 0.12,      "$type": "number" }
  },

  "accessibility": {
    "min_contrast_body":  { "$value": 7.0, "$type": "number" },
    "min_contrast_large": { "$value": 4.5, "$type": "number" },
    "min_touch_target":   { "$value": "44px", "$type": "dimension" }
  }
}
