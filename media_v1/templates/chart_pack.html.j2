{# editorial_press_v1 — chart_pack.html.j2
   One chart per row, each with caption + source URL. Charts ship as
   transparent-bg PNG + SVG so newsroom CMS controls the host surface.
   Context: { lang, topic, embargo, dateline, charts[],
              audit_url, license, attribution }
   chart shape: { id, title, alt_text, png_url, svg_url, caption,
                  source_label, source_url, prosper_pillar (optional) } #}
<!DOCTYPE html>
<html lang="{{ lang|default('de') }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  {% if embargo %}<meta name="robots" content="noindex,nofollow">{% endif %}
  <title>{{ ui.chart_pack|default('Grafikpaket') }} — {{ topic|e }}</title>
  <link rel="stylesheet" href="kit.css">
  <style>:root { --audit-url: "{{ audit_url }}"; }</style>
</head>
<body class="{{ 'watermarked' if embargo else '' }}">
  <a href="#main" class="skip-link">{{ ui.skip_to_content|default('Zum Inhalt') }}</a>

  {% if embargo %}
  <div class="embargo-banner" role="note">
    {{ ui.embargo|default('SPERRFRIST') }}
    <span class="embargo-banner__time">{{ embargo.release_at|e }} ({{ embargo.tz|default('CET') }})</span>
  </div>
  {% endif %}

  <main id="main">

    <header class="masthead">
      <span class="masthead__brand">PTT Platform · {{ ui.chart_pack|default('Grafikpaket') }}</span>
      <span class="masthead__date">{{ dateline.date|e }}</span>
    </header>

    <p class="dateline">{{ topic|e }}</p>
    <h1 class="headline" style="font-size:28px;">{{ ui.chart_pack|default('Grafikpaket') }}</h1>
    <p class="lede">{{ ui.chart_pack_lede|default('Druckfertige Visuals mit transparentem Hintergrund. PNG + SVG, Alt-Text in 3 Sprachen.') }}</p>

    {% for chart in charts %}
    <figure class="chart-row" id="{{ chart.id|e }}">
      <div class="chart-row__figure">
        {# Renderer prefers SVG embed; PNG fallback served via <img> #}
        <img src="{{ chart.png_url }}"
             alt="{{ chart.alt_text|e }}"
             width="720" height="320"
             loading="lazy"
             style="max-width:100%;height:auto;background:transparent;">
      </div>
      <figcaption class="chart-row__caption">
        <strong>{{ chart.title|e }}</strong>
        {% if chart.prosper_pillar %} · <span class="confidence-badge">{{ chart.prosper_pillar|e }}</span>{% endif %}
        <br>
        {{ chart.caption|e }}
        <span class="chart-row__source">
          {{ ui.source|default('Quelle') }}:
          {% if chart.source_url %}<a href="{{ chart.source_url }}">{{ chart.source_label|default(chart.source_url)|e }}</a>{% else %}{{ chart.source_label|e }}{% endif %}
          · {{ ui.svg_alt|default('SVG-Variante') }}: <a href="{{ chart.svg_url }}">{{ chart.svg_url|e }}</a>
        </span>
      </figcaption>
    </figure>
    {% endfor %}

    <footer class="audit-footer">
      <span>Audit: <a href="{{ audit_url }}">{{ audit_url }}</a></span>
      <span>{{ ui.license|default('Lizenz') }}: {{ license|default('CC-BY-4.0') }}</span>
      <span>{{ attribution|e }}</span>
    </footer>

  </main>
</body>
</html>
