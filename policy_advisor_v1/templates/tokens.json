{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Parliamentary-classic token kit for policy_advisor_v1. Federal-grade serif throughout (Source Serif 4 heading + body), navy + gold accents with structured table tokens for legal side-by-side comparisons and dense Q&A. Reference style: UK Cabinet Office One-Page Brief, Bundeskanzlei Botschaftsformat, Federal Chancellery 'note d'analyse'.",
  "$kit": "parliamentary_classic",
  "$package_id": "policy_advisor_v1",
  "$version": "1.0.0",

  "color": {
    "brand": {
      "navy":       { "$value": "#1B2A4A", "$type": "color" },
      "gold":       { "$value": "#C9A84C", "$type": "color" },
      "white":      { "$value": "#FFFFFF", "$type": "color" },
      "body":       { "$value": "#2C2C2C", "$type": "color" },
      "light_gray": { "$value": "#F5F5F5", "$type": "color" }
    },
    "parl": {
      "ink":           { "$value": "#10182B", "$type": "color", "$description": "Body ink — sits between #0F1A30 and #1B2A4A. Contrast on white: 16.8:1." },
      "ink_secondary": { "$value": "#46505F", "$type": "color", "$description": "Footnote / source-citation. Contrast on white: 8.4:1." },
      "paper":         { "$value": "#FDFCF7", "$type": "color", "$description": "Slight warm cast — Bundeskanzlei dossier paper." },
      "rule_strong":   { "$value": "#1B2A4A", "$type": "color", "$description": "1pt page-header rule." },
      "rule_med":      { "$value": "#9CA0AC", "$type": "color", "$description": "0.5pt section divider." },
      "rule_hair":     { "$value": "#D8D5C9", "$type": "color", "$description": "0.25pt table hairlines." },
      "table_zebra":   { "$value": "#F7F4EC", "$type": "color", "$description": "Alternate row tint, ~3% above paper. Reads as 'present' on screen, vanishes on duplex print." },
      "diff_add":      { "$value": "#E2EFE6", "$type": "color", "$description": "Side-by-side comparison: added clauses. Background only; text remains ink." },
      "diff_del":      { "$value": "#F8E5E5", "$type": "color", "$description": "Side-by-side comparison: deleted clauses." },
      "diff_mod":      { "$value": "#FFF6CC", "$type": "color", "$description": "Side-by-side comparison: modified clauses." },
      "callout":       { "$value": "#EAEEF7", "$type": "color", "$description": "Pull-quote / margin note." },
      "annotation":    { "$value": "#7A6A24", "$type": "color", "$description": "PROSPER pillar annotation badge text. Darker gold for AAA contrast on white: 7.1:1." }
    },
    "data": {
      "score_excellent":  { "$value": "#1B5E20", "$type": "color" },
      "score_good":       { "$value": "#2E7D32", "$type": "color" },
      "score_moderate":   { "$value": "#F9A825", "$type": "color" },
      "score_poor":       { "$value": "#E65100", "$type": "color" },
      "score_critical":   { "$value": "#C62828", "$type": "color" }
    },
    "text": {
      "default":   { "$value": "{color.parl.ink.value}", "$type": "color" },
      "muted":     { "$value": "{color.parl.ink_secondary.value}", "$type": "color" },
      "on_navy":   { "$value": "{color.brand.white.value}", "$type": "color" },
      "on_gold":   { "$value": "{color.brand.navy.value}", "$type": "color" }
    }
  },

  "typography": {
    "font_family": {
      "heading": { "$value": "\"Source Serif 4\", Charter, Georgia, serif", "$type": "fontFamily", "$description": "Serif heading anchors federal authority. Pairs with body family." },
      "body":    { "$value": "\"Source Serif 4\", Charter, Georgia, serif", "$type": "fontFamily" },
      "numeric": { "$value": "\"Source Serif 4\", ui-monospace, monospace", "$type": "fontFamily", "$description": "Tabular figures via OpenType `tnum`." },
      "legal":   { "$value": "\"Source Serif 4\", Charter, Georgia, serif", "$type": "fontFamily", "$description": "Article-citation runs (e.g. 'art. 8 al. 2 LPE')." }
    },
    "font_size": {
      "h1":         { "$value": "18pt", "$type": "dimension" },
      "h2":         { "$value": "13pt", "$type": "dimension" },
      "h3":         { "$value": "11pt", "$type": "dimension" },
      "body":       { "$value": "10pt", "$type": "dimension", "$description": "Dense — parliamentary briefs run 4 pages, so body sits compact." },
      "body_web":   { "$value": "15px", "$type": "dimension" },
      "table_body": { "$value": "9pt",  "$type": "dimension" },
      "footnote":   { "$value": "8pt",  "$type": "dimension" },
      "caption":    { "$value": "8pt",  "$type": "dimension" }
    },
    "line_height": {
      "tight":  { "$value": "1.10", "$type": "number" },
      "snug":   { "$value": "1.30", "$type": "number" },
      "normal": { "$value": "1.45", "$type": "number" },
      "loose":  { "$value": "1.60", "$type": "number" }
    },
    "scale_ratio": { "$value": "1.250", "$type": "number" },
    "font_weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "numerals": { "$value": "tabular", "$type": "string" }
  },

  "spacing": {
    "0": { "$value": "0",    "$type": "dimension" },
    "1": { "$value": "2pt",  "$type": "dimension" },
    "2": { "$value": "4pt",  "$type": "dimension" },
    "3": { "$value": "6pt",  "$type": "dimension" },
    "4": { "$value": "8pt",  "$type": "dimension" },
    "5": { "$value": "12pt", "$type": "dimension" },
    "6": { "$value": "16pt", "$type": "dimension" },
    "7": { "$value": "20pt", "$type": "dimension" },
    "8": { "$value": "28pt", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",   "$type": "dimension", "$description": "Parliamentary kit has zero corner radius — federal sober." },
    "sm":   { "$value": "1px", "$type": "dimension" }
  },

  "shadow": {
    "none": { "$value": "none", "$type": "shadow" }
  },

  "motion": {
    "respect_reduced_motion": { "$value": true, "$type": "boolean" }
  },

  "layout": {
    "max_content_width":   { "$value": "780px", "$type": "dimension" },
    "two_column_gap":      { "$value": "16pt",  "$type": "dimension" },
    "side_by_side_min_w":  { "$value": "320px", "$type": "dimension" },
    "print_a4_w":          { "$value": "210mm", "$type": "dimension" },
    "print_a4_h":          { "$value": "297mm", "$type": "dimension" },
    "print_a4_margin":     { "$value": "20mm",  "$type": "dimension", "$description": "Wider margins than executive kit — parliamentary briefs are often annotated." },
    "pptx_w_in":           { "$value": "13.333", "$type": "number" },
    "pptx_h_in":           { "$value": "7.5",   "$type": "number" }
  },

  "accessibility": {
    "min_contrast_body":  { "$value": 7.0, "$type": "number" },
    "min_contrast_large": { "$value": 4.5, "$type": "number" },
    "min_touch_target":   { "$value": "44px", "$type": "dimension" }
  }
}
