{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Business-sober token kit for entrepreneur_v1. McKinsey 2-pager + KKR board-pack visual conventions: cool grey base, gold accent, financial-spreadsheet typography (Inter + Inter Mono), NOGA-coded row palette for sector exposure, CHF figures with non-breaking spaces. Reference NAVY/GOLD via {color.brand.navy.value} — never inline.",
  "$kit": "business_sober_v1",
  "$package_id": "entrepreneur_v1",
  "$version": "1.0.0",

  "color": {
    "brand": {
      "navy":       { "$value": "#1B2A4A", "$type": "color", "$description": "Canonical PTT navy." },
      "gold":       { "$value": "#C9A84C", "$type": "color", "$description": "Canonical PTT gold." },
      "white":      { "$value": "#FFFFFF", "$type": "color", "$description": "Canonical PTT white." },
      "body":       { "$value": "#2C2C2C", "$type": "color", "$description": "Canonical PTT body text." },
      "light_gray": { "$value": "#F5F5F5", "$type": "color", "$description": "Canonical PTT light gray." }
    },
    "biz": {
      "ink":            { "$value": "#111827", "$type": "color", "$description": "Body ink. On white: 16.9:1." },
      "ink_secondary":  { "$value": "#374151", "$type": "color", "$description": "Caption / footnote. On white: 10.4:1." },
      "ink_muted":      { "$value": "#6B7280", "$type": "color", "$description": "Metadata. On white: 4.8:1." },
      "paper":          { "$value": "#FFFFFF", "$type": "color", "$description": "Default board-deck paper." },
      "panel":          { "$value": "#F3F4F6", "$type": "color", "$description": "Risk-register panel background." },
      "panel_alt":      { "$value": "#E5E7EB", "$type": "color", "$description": "Spreadsheet header band." },
      "rule_strong":    { "$value": "#111827", "$type": "color", "$description": "1pt section rule." },
      "rule_med":       { "$value": "#9CA3AF", "$type": "color", "$description": "0.5pt divider." },
      "rule_hair":      { "$value": "#D1D5DB", "$type": "color", "$description": "0.25pt table hairline." },
      "accent_gold":    { "$value": "#C9A84C", "$type": "color", "$description": "Recommendation band, never used as body text." },
      "lever_left":     { "$value": "#1B2A4A", "$type": "color", "$description": "Mitigation lever left rule." }
    },
    "noga": {
      "$description": "NOGA division row palette. Each NOGA division (A, B, C, ..., U) gets a low-saturation tint that survives B/W print. Used in sector exposure tables only — never on charts.",
      "A": { "$value": "#E8F0E5", "$type": "color", "$description": "Agriculture, forestry, fishing." },
      "B": { "$value": "#EFE5DD", "$type": "color", "$description": "Mining and quarrying." },
      "C": { "$value": "#E2E8EE", "$type": "color", "$description": "Manufacturing." },
      "D": { "$value": "#F0EAD9", "$type": "color", "$description": "Electricity, gas, steam." },
      "E": { "$value": "#E1ECEC", "$type": "color", "$description": "Water supply, waste management." },
      "F": { "$value": "#EAE3E0", "$type": "color", "$description": "Construction." },
      "G": { "$value": "#E6E6F0", "$type": "color", "$description": "Wholesale, retail, vehicle repair." },
      "H": { "$value": "#E0E8EE", "$type": "color", "$description": "Transportation, storage." },
      "I": { "$value": "#F0E5E0", "$type": "color", "$description": "Accommodation, food service." },
      "J": { "$value": "#E0E8E5", "$type": "color", "$description": "Information, communication." },
      "K": { "$value": "#EBE5E5", "$type": "color", "$description": "Financial, insurance." },
      "L": { "$value": "#EAE7E0", "$type": "color", "$description": "Real estate." },
      "M": { "$value": "#E5EAEE", "$type": "color", "$description": "Professional, scientific, technical." },
      "N": { "$value": "#EBE6E0", "$type": "color", "$description": "Administrative, support." },
      "O": { "$value": "#E2E5EE", "$type": "color", "$description": "Public administration." },
      "P": { "$value": "#E8E5EE", "$type": "color", "$description": "Education." },
      "Q": { "$value": "#E5EEE5", "$type": "color", "$description": "Human health, social work." },
      "R": { "$value": "#EEE5E5", "$type": "color", "$description": "Arts, entertainment, recreation." },
      "S": { "$value": "#E5EEEC", "$type": "color", "$description": "Other services." },
      "T": { "$value": "#EEE9E2", "$type": "color", "$description": "Households as employers." },
      "U": { "$value": "#E2EAEE", "$type": "color", "$description": "Extraterritorial organisations." }
    },
    "impact_band": {
      "$description": "CHF impact band tints. Never inverted: low = pale, high = saturated.",
      "lt_100k":  { "$value": "#F0FDF4", "$type": "color", "$description": "<CHF 100k." },
      "100k_1m":  { "$value": "#FEF9C3", "$type": "color", "$description": "CHF 100k–1M." },
      "1m_10m":   { "$value": "#FED7AA", "$type": "color", "$description": "CHF 1M–10M." },
      "gt_10m":   { "$value": "#FECACA", "$type": "color", "$description": ">CHF 10M." }
    },
    "data": {
      "score_excellent":  { "$value": "#1B5E20", "$type": "color" },
      "score_good":       { "$value": "#2E7D32", "$type": "color" },
      "score_moderate":   { "$value": "#F9A825", "$type": "color" },
      "score_poor":       { "$value": "#E65100", "$type": "color" },
      "score_critical":   { "$value": "#C62828", "$type": "color" }
    },
    "text": {
      "default":   { "$value": "{color.biz.ink.value}", "$type": "color" },
      "muted":     { "$value": "{color.biz.ink_secondary.value}", "$type": "color" },
      "on_navy":   { "$value": "{color.brand.white.value}", "$type": "color" },
      "on_gold":   { "$value": "{color.brand.navy.value}", "$type": "color" }
    }
  },

  "typography": {
    "font_family": {
      "heading": { "$value": "Inter, -apple-system, BlinkMacSystemFont, sans-serif", "$type": "fontFamily", "$description": "Inter heading — board-grade neutral." },
      "body":    { "$value": "Inter, system-ui, sans-serif", "$type": "fontFamily", "$description": "Inter body — matches the heading family for spreadsheet-like consistency." },
      "numeric": { "$value": "\"Inter\", \"JetBrains Mono\", ui-monospace, monospace", "$type": "fontFamily", "$description": "Inter Mono for figures (font-feature-settings: tnum, lnum). Falls back to JetBrains Mono if Inter Mono is unavailable." }
    },
    "font_size": {
      "h1":         { "$value": "20pt", "$type": "dimension" },
      "h2":         { "$value": "14pt", "$type": "dimension" },
      "h3":         { "$value": "11pt", "$type": "dimension" },
      "body":       { "$value": "10pt", "$type": "dimension", "$description": "Dense — board memos run 2 pages, so body sits compact." },
      "body_web":   { "$value": "15px", "$type": "dimension" },
      "table_body": { "$value": "9pt",  "$type": "dimension" },
      "footnote":   { "$value": "8pt",  "$type": "dimension" },
      "caption":    { "$value": "8pt",  "$type": "dimension" },
      "kpi_value":  { "$value": "28pt", "$type": "dimension" }
    },
    "line_height": {
      "tight":  { "$value": "1.10", "$type": "number" },
      "snug":   { "$value": "1.30", "$type": "number" },
      "normal": { "$value": "1.45", "$type": "number" },
      "loose":  { "$value": "1.60", "$type": "number" }
    },
    "scale_ratio": { "$value": "1.250", "$type": "number" },
    "font_weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "numerals":         { "$value": "tabular", "$type": "string" },
    "currency_format":  { "$value": "CHF 1 234 567", "$type": "string", "$description": "Non-breaking thin-space thousands separator. CHF unit always preceded by non-breaking space." }
  },

  "spacing": {
    "0": { "$value": "0",    "$type": "dimension" },
    "1": { "$value": "2pt",  "$type": "dimension" },
    "2": { "$value": "4pt",  "$type": "dimension" },
    "3": { "$value": "6pt",  "$type": "dimension" },
    "4": { "$value": "8pt",  "$type": "dimension" },
    "5": { "$value": "12pt", "$type": "dimension" },
    "6": { "$value": "16pt", "$type": "dimension" },
    "7": { "$value": "20pt", "$type": "dimension" },
    "8": { "$value": "28pt", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",   "$type": "dimension", "$description": "Board kit has zero radius — sober McKinsey 2-pager." },
    "sm":   { "$value": "2px", "$type": "dimension" }
  },

  "shadow": { "none": { "$value": "none", "$type": "shadow" } },

  "motion": { "respect_reduced_motion": { "$value": true, "$type": "boolean" } },

  "layout": {
    "max_content_width":   { "$value": "780px", "$type": "dimension" },
    "two_col_gap":         { "$value": "12pt",  "$type": "dimension" },
    "print_a4_w":          { "$value": "210mm", "$type": "dimension" },
    "print_a4_h":          { "$value": "297mm", "$type": "dimension" },
    "print_a4_margin":     { "$value": "16mm",  "$type": "dimension", "$description": "Tight margins — board memos use the full page." },
    "pptx_w_in":           { "$value": "13.333", "$type": "number" },
    "pptx_h_in":           { "$value": "7.5",   "$type": "number" }
  },

  "accessibility": {
    "min_contrast_body":  { "$value": 7.0, "$type": "number" },
    "min_contrast_large": { "$value": 4.5, "$type": "number" },
    "min_touch_target":   { "$value": "44px", "$type": "dimension" }
  }
}
