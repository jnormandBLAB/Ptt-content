{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Civic-warm token kit for citizen_v1. Extends ptt_navy_gold with a softer secondary blue (federal voting brochure 2024) and a warm cream surface. Targets large-numeral hero infographics, social cards, and A5 print on warm-white stock. Reference the canonical NAVY/GOLD via {color.brand.navy.value} — never inline.",
  "$kit": "citizen_civic_warm",
  "$package_id": "citizen_v1",
  "$version": "1.0.0",

  "color": {
    "brand": {
      "navy":       { "$value": "#1B2A4A", "$type": "color", "$description": "Canonical PTT navy. Source: src/ptt_ui/config.py NAVY." },
      "gold":       { "$value": "#C9A84C", "$type": "color", "$description": "Canonical PTT gold. Source: src/ptt_ui/config.py GOLD." },
      "white":      { "$value": "#FFFFFF", "$type": "color", "$description": "Canonical PTT white." },
      "body":       { "$value": "#2C2C2C", "$type": "color", "$description": "Canonical PTT body text." },
      "light_gray": { "$value": "#F5F5F5", "$type": "color", "$description": "Canonical PTT light gray." }
    },
    "civic": {
      "blue":       { "$value": "#4A6FA5", "$type": "color", "$description": "Civic-blue secondary, mid-saturation. Lifts cards out of pure-navy density without competing with brand. Contrast on cream: 4.62:1." },
      "blue_soft":  { "$value": "#A8BDD8", "$type": "color", "$description": "Hairline divider and quoted-callout background. NEVER for body text." },
      "warm_white": { "$value": "#FBF7EE", "$type": "color", "$description": "Default surface. Pulled from voting-brochure paper stock; reduces glare in WhatsApp dark previews." },
      "cream":      { "$value": "#F4ECD8", "$type": "color", "$description": "Card surface for shock-stat hero. Warm enough to feel postal, neutral enough to read on phones." }
    },
    "semantic": {
      "support":    { "$value": "#1B5E20", "$type": "color", "$description": "Pro/support visualisation. Contrast on warm_white: 7.81:1." },
      "oppose":     { "$value": "#A32D2D", "$type": "color", "$description": "Con/oppose visualisation. Mirrors PTT RED. Contrast on warm_white: 6.42:1." },
      "neutral":    { "$value": "#7B6F58", "$type": "color", "$description": "Undecided / abstain. Warm gray, paired with cream surface." },
      "warning":    { "$value": "#854F0B", "$type": "color", "$description": "Time-sensitive nudge (vote date approaching). Mirrors PTT AMBER." },
      "divider":    { "$value": "#E1D6BB", "$type": "color", "$description": "Hairline on cream. 1px. Never used for primary structure." },
      "link":       { "$value": "#1B2A4A", "$type": "color", "$description": "Links use brand navy + underline; never the civic-blue (which is reserved for surfaces)." }
    },
    "text": {
      "default":    { "$value": "{color.brand.body.value}", "$type": "color" },
      "muted":      { "$value": "#5A5040", "$type": "color", "$description": "Captions on cream. Contrast: 7.21:1." },
      "on_navy":    { "$value": "{color.brand.white.value}", "$type": "color" },
      "on_gold":    { "$value": "{color.brand.navy.value}", "$type": "color", "$description": "Gold backgrounds always carry navy text. Contrast: 7.45:1." }
    }
  },

  "typography": {
    "font_family": {
      "heading": { "$value": "Inter, -apple-system, BlinkMacSystemFont, sans-serif", "$type": "fontFamily", "$description": "Inter for headings — clean, neutral, federal-aligned." },
      "body":    { "$value": "Inter, system-ui, sans-serif", "$type": "fontFamily", "$description": "Inter system stack for body. Optimises for phone-first reading." },
      "numeric": { "$value": "Inter, ui-monospace, monospace", "$type": "fontFamily", "$description": "Tabular figures for hero stats (font-feature-settings: 'tnum')." }
    },
    "font_size": {
      "hero":      { "$value": "72px",  "$type": "dimension", "$description": "Shock-stat numeral, social-square only. Drops to 56px on web." },
      "display":   { "$value": "44px",  "$type": "dimension" },
      "h1":        { "$value": "32px",  "$type": "dimension" },
      "h2":        { "$value": "24px",  "$type": "dimension" },
      "h3":        { "$value": "20px",  "$type": "dimension" },
      "body":      { "$value": "18px",  "$type": "dimension", "$description": "Body floor — citizen kit reads on phones; 18px is the WCAG-comfortable minimum." },
      "body_print":{ "$value": "11pt",  "$type": "dimension", "$description": "A5 print body. Equates to 18px digital." },
      "caption":   { "$value": "14px",  "$type": "dimension" },
      "footnote":  { "$value": "9pt",   "$type": "dimension", "$description": "Print footer with audit URL + license." }
    },
    "line_height": {
      "tight":   { "$value": "1.15", "$type": "number" },
      "snug":    { "$value": "1.30", "$type": "number" },
      "normal":  { "$value": "1.55", "$type": "number", "$description": "Body floor — generous because lay readers re-read." },
      "loose":   { "$value": "1.70", "$type": "number" }
    },
    "scale_ratio": { "$value": "1.250", "$type": "number", "$description": "Major third. Lay-friendly, generous step between sizes." },
    "font_weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "numerals": { "$value": "lining", "$type": "string", "$description": "Lining figures everywhere — old-style figures look out of place at 72px shock-stat scale." }
  },

  "spacing": {
    "0":   { "$value": "0",     "$type": "dimension" },
    "1":   { "$value": "4px",   "$type": "dimension" },
    "2":   { "$value": "8px",   "$type": "dimension", "$description": "8px rhythm anchor." },
    "3":   { "$value": "12px",  "$type": "dimension" },
    "4":   { "$value": "16px",  "$type": "dimension" },
    "5":   { "$value": "24px",  "$type": "dimension" },
    "6":   { "$value": "32px",  "$type": "dimension" },
    "7":   { "$value": "48px",  "$type": "dimension" },
    "8":   { "$value": "64px",  "$type": "dimension", "$description": "Social-card breathing room." },
    "9":   { "$value": "96px",  "$type": "dimension", "$description": "Story 1080x1920 vertical padding only." }
  },

  "radius": {
    "sm":   { "$value": "4px",   "$type": "dimension" },
    "md":   { "$value": "10px",  "$type": "dimension", "$description": "Card default — matches Streamlit UI radius." },
    "lg":   { "$value": "16px",  "$type": "dimension", "$description": "Hero infographic and WhatsApp card." },
    "pill": { "$value": "999px", "$type": "dimension", "$description": "Vote-date badge only." }
  },

  "shadow": {
    "none":    { "$value": "none",                                 "$type": "shadow" },
    "subtle":  { "$value": "0 1px 2px rgba(27,42,74,0.06)",        "$type": "shadow", "$description": "Web cards — never on print." },
    "lifted":  { "$value": "0 4px 12px rgba(27,42,74,0.10)",       "$type": "shadow", "$description": "Hero infographic on web only." },
    "ring":    { "$value": "0 0 0 3px rgba(201,168,76,0.40)",      "$type": "shadow", "$description": "Focus ring — gold halo on interactive." }
  },

  "motion": {
    "duration": {
      "fast":    { "$value": "120ms", "$type": "duration" },
      "default": { "$value": "200ms", "$type": "duration" },
      "slow":    { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "standard":  { "$value": "cubic-bezier(0.2, 0, 0, 1)",     "$type": "cubicBezier" },
      "decel":     { "$value": "cubic-bezier(0, 0, 0.2, 1)",      "$type": "cubicBezier" },
      "accel":     { "$value": "cubic-bezier(0.4, 0, 1, 1)",      "$type": "cubicBezier" }
    },
    "respect_reduced_motion": { "$value": true, "$type": "boolean", "$description": "All transitions wrapped in @media (prefers-reduced-motion: reduce) → none." }
  },

  "layout": {
    "max_content_width":      { "$value": "640px",   "$type": "dimension", "$description": "Web reading column — phone-first, 38em." },
    "social_square":          { "$value": "1080px",  "$type": "dimension" },
    "social_landscape_w":     { "$value": "1200px",  "$type": "dimension" },
    "social_landscape_h":     { "$value": "630px",   "$type": "dimension" },
    "social_story_w":         { "$value": "1080px",  "$type": "dimension" },
    "social_story_h":         { "$value": "1920px",  "$type": "dimension" },
    "whatsapp_card_w":        { "$value": "800px",   "$type": "dimension" },
    "print_a5_w":             { "$value": "148mm",   "$type": "dimension" },
    "print_a5_h":             { "$value": "210mm",   "$type": "dimension" },
    "print_a5_margin":        { "$value": "12mm",    "$type": "dimension" }
  },

  "accessibility": {
    "min_contrast_body":  { "$value": 4.5, "$type": "number" },
    "min_contrast_large": { "$value": 3.0, "$type": "number" },
    "min_touch_target":   { "$value": "44px", "$type": "dimension" },
    "focus_outline":      { "$value": "{shadow.ring.value}", "$type": "shadow" }
  }
}
