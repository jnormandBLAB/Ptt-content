{# citizen_civic_warm — email_body.html.j2
   Inline-styled email body for civic newsletter delivery. Uses tables for
   Gmail/Outlook 2007-2019 compatibility. Body width 600px (industry default).
   Context: { lang, hero, brief, audit_url, license, attribution } #}
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="{{ lang|default('fr') }}">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ hero.title|e }}</title>
</head>
<body style="margin:0;padding:0;background:#FBF7EE;font-family:Inter,Arial,sans-serif;color:#2C2C2C;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#FBF7EE">
    <tr>
      <td align="center" style="padding:24px 12px;">

        <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0"
               style="max-width:600px;background:#FFFFFF;border-radius:10px;border:1px solid #E1D6BB;">
          <tr>
            <td style="padding:32px 24px 16px 24px;">
              <span style="display:inline-block;background:#C9A84C;color:#1B2A4A;font-size:14px;font-weight:600;padding:4px 12px;border-radius:999px;">
                Vote&nbsp;: {{ vote_date|default('—') }}
              </span>
            </td>
          </tr>
          <tr>
            <td align="center" bgcolor="#F4ECD8" style="padding:32px 24px;">
              <p style="margin:0;font-size:48px;line-height:1.1;color:#1B2A4A;font-weight:700;">{{ hero.stat|e }}</p>
              <p style="margin:12px 0 0 0;font-size:18px;line-height:1.35;color:#5A5040;">{{ hero.caption|e }}</p>
            </td>
          </tr>
          <tr>
            <td style="padding:24px;">
              <h2 style="margin:0 0 12px 0;font-size:22px;color:#1B2A4A;font-weight:600;">{{ brief.title|e }}</h2>
              {% for para in brief.paragraphs|default([]) %}
              <p style="margin:0 0 16px 0;font-size:16px;line-height:1.55;">{{ para|e }}</p>
              {% endfor %}
            </td>
          </tr>
          <tr>
            <td style="padding:16px 24px 24px 24px;border-top:1px solid #E1D6BB;font-size:13px;color:#5A5040;line-height:1.45;">
              <p style="margin:0 0 6px 0;">Audit&nbsp;: <a href="{{ audit_url }}" style="color:#1B2A4A;">{{ audit_url }}</a></p>
              <p style="margin:0 0 6px 0;">Licence&nbsp;: {{ license|default('CC BY 4.0') }}</p>
              <p style="margin:0;">{{ attribution|e }}</p>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>
</body>
</html>
