{# citizen_civic_warm — social_story_1080x1920.html.j2
   Vertical story (Instagram / WhatsApp Status). 1080x1920, safe area 1080x1500
   centred to dodge UI chrome top/bottom.
   Context: { lang, hero, vote_date, brief_one_liner, attribution_short } #}
<!DOCTYPE html>
<html lang="{{ lang|default('fr') }}">
<head>
  <meta charset="utf-8">
  <title>{{ hero.title|e }}</title>
  <link rel="stylesheet" href="kit.css">
  <style>
    html, body { margin: 0; padding: 0; }
    .story {
      width: 1080px;
      height: 1920px;
      padding: 200px 96px 240px 96px;
      box-sizing: border-box;
      background: linear-gradient(180deg, #F4ECD8 0%, #FBF7EE 60%, #F4ECD8 100%);
      color: var(--ptt-navy);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .story__pill {
      align-self: flex-start;
      background: var(--ptt-gold);
      color: var(--ptt-navy);
      font-size: 28px;
      font-weight: 700;
      padding: 12px 24px;
      border-radius: 999px;
    }
    .story__stat {
      font-family: var(--ff-numeric);
      font-feature-settings: "tnum" 1, "lnum" 1;
      font-size: 320px;
      line-height: 0.92;
      font-weight: 800;
      letter-spacing: -0.04em;
      text-align: center;
      margin: 0;
    }
    .story__caption {
      font-size: 44px;
      line-height: 1.30;
      text-align: center;
      color: #3A3528;
      margin-top: 32px;
    }
    .story__one_liner {
      font-size: 32px;
      line-height: 1.40;
      text-align: center;
      color: var(--ptt-navy);
      font-weight: 600;
    }
    .story__brand { font-size: 22px; text-align: center; color: #5A5040; }
  </style>
</head>
<body>
  <div class="story" role="img" aria-label="{{ hero.alt_text|default(hero.caption)|e }}">
    <span class="story__pill">Vote&nbsp;: {{ vote_date }}</span>
    <div>
      <p class="story__stat">{{ hero.stat|e }}</p>
      <p class="story__caption">{{ hero.caption|e }}</p>
    </div>
    <div>
      <p class="story__one_liner">{{ brief_one_liner|e }}</p>
      <p class="story__brand">PTT&nbsp;Platform · {{ attribution_short|default('CC BY 4.0') }}</p>
    </div>
  </div>
</body>
</html>
